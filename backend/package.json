{
  "name": "@flightbrain/backend",
  "version": "0.1.0",
  "description": "FlightBrain Backend - Fee-to-travel-credits pipeline for Bags.fm",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",

    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/static": "^9.0.0",
    "@solana/web3.js": "^1.95.0",
    "dotenv": "^17.0.0",
    "fastify": "^5.1.0",
    "node-cron": "^4.0.0",
    "pg": "^8.13.0",
    "pino": "^10.0.0",
    "pino-pretty": "^13.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.0",
    "@vitest/coverage-v8": "^4.1.2",
    "rimraf": "^5.0.5",
    "tsx": "^4.20.6",

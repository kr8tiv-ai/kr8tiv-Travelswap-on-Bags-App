# ─── FlightBrain Environment Configuration ─────────────────────
# Copy to .env and fill in real values before running.

# ── Required Secrets ──────────────────────────────────────────
BAGS_API_KEY=<from bags.fm/developers>
BAGS_API_BASE_URL=https://public-api-v2.bags.fm/api/v1
HELIUS_API_KEY=<from helius.dev>
API_AUTH_TOKEN=<bearer token for FlightBrain API routes>
SIGNER_PRIVATE_KEY=<base58 solana keypair>

# ── Travel-Specific ──────────────────────────────────────────
# 32-byte hex key for AES-256-GCM gift card code encryption
GIFT_CARD_ENCRYPTION_KEY=<64-char hex string>
GIFT_CARD_DAILY_LIMIT=20
GIFT_CARD_MAX_DENOMINATION=200
BALANCE_MAX_USD=1000

# ── Execution Controls ───────────────────────────────────────
DRY_RUN=false
EXECUTION_KILL_SWITCH=false
MAX_DAILY_RUNS=4
MAX_CLAIMABLE_SOL_PER_RUN=100

# ── Fee & Swap Settings ─────────────────────────────────────
FEE_THRESHOLD_SOL=5
FEE_SOURCE=CLAIMABLE_POSITIONS
SWAP_SLIPPAGE_BPS=50

# ── Distribution ─────────────────────────────────────────────
DISTRIBUTION_MODE=TOP_N_HOLDERS
DISTRIBUTION_TOP_N=100

# ── Credit Mode ──────────────────────────────────────────────
# GIFT_CARD | DIRECT_TOPUP | DUFFEL_BOOKING
CREDIT_MODE=GIFT_CARD

# ── Scheduling ───────────────────────────────────────────────
CRON_EXPRESSION=0 */6 * * *

# ── Server ───────────────────────────────────────────────────
PORT=3001
CORS_ORIGINS=

# ── Database ─────────────────────────────────────────────────
DATABASE_PATH=./data/flightbrain.db

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development

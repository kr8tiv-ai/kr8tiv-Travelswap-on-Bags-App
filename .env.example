# ═══════════════════════════════════════════════════════════════════
# FlightBrain Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env.docker (for Docker) or .env (for local dev)
# and fill in the values.
#
# Required fields are marked [REQUIRED]; others have sensible defaults.
# ═══════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────
# PostgreSQL connection string. When set, uses PostgreSQL; when absent, falls back to SQLite.
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://flightbrain:flightbrain_dev@postgres:5432/flightbrain

# SQLite database path (used when DATABASE_URL is not set)
# DATABASE_PATH=./data/flightbrain.db

# ── Required Secrets ──────────────────────────────────────────────
# [REQUIRED] Bags.fm API key for claimable position queries
BAGS_API_KEY=

# [REQUIRED] Helius RPC API key for Solana blockchain access
HELIUS_API_KEY=

# [REQUIRED] Bearer token for authenticating API requests
API_AUTH_TOKEN=

# [REQUIRED] Exactly 64 hex characters (32 bytes) for AES-256 gift card encryption
# Example: openssl rand -hex 32
GIFT_CARD_ENCRYPTION_KEY=

# ── Optional Secrets ──────────────────────────────────────────────
# Solana wallet private key for signing transactions (base58 encoded)
# SIGNER_PRIVATE_KEY=

# Duffel API token for flight search/booking (only needed if flight features are used)
# DUFFEL_API_TOKEN=

# ── Execution Controls ───────────────────────────────────────────
# When true, pipeline runs simulate without executing real transactions
DRY_RUN=true

# Emergency stop — prevents any pipeline execution when true
EXECUTION_KILL_SWITCH=false

# Maximum pipeline runs allowed per 24-hour window
MAX_DAILY_RUNS=4

# Maximum SOL value of claimable positions to process per run
MAX_CLAIMABLE_SOL_PER_RUN=100

# ── Fee & Swap Settings ──────────────────────────────────────────
# Minimum SOL threshold before fee collection triggers (0.1–100)
FEE_THRESHOLD_SOL=5

# Fee source: CLAIMABLE_POSITIONS or PARTNER_FEES
FEE_SOURCE=CLAIMABLE_POSITIONS

# Swap slippage tolerance in basis points (0–1000; 50 = 0.5%)
SWAP_SLIPPAGE_BPS=50

# ── Distribution ──────────────────────────────────────────────────
# How to distribute USDC to holders: OWNER_ONLY | TOP_N_HOLDERS | EQUAL_SPLIT | WEIGHTED_BY_HOLDINGS | CUSTOM_LIST
DISTRIBUTION_MODE=TOP_N_HOLDERS

# Number of top holders to include (when mode is TOP_N_HOLDERS)
DISTRIBUTION_TOP_N=100

# ── Credit ────────────────────────────────────────────────────────
# Credit delivery method: GIFT_CARD | DIRECT_TOPUP | DUFFEL_BOOKING
CREDIT_MODE=GIFT_CARD

# Maximum gift cards purchasable per day
GIFT_CARD_DAILY_LIMIT=20

# Maximum denomination per gift card in USD
GIFT_CARD_MAX_DENOMINATION=200

# Maximum travel balance per user in USD
BALANCE_MAX_USD=1000

# Partner reference identifier for TravelSwap
TRAVELSWAP_PARTNER_REF=FLIGHTBRAIN

# ── Scheduling ────────────────────────────────────────────────────
# Cron expression for automated pipeline runs (default: every 6 hours)
CRON_EXPRESSION=0 */6 * * *

# ── Server ────────────────────────────────────────────────────────
# HTTP port for the API server
PORT=3001

# Environment: development | production | test
NODE_ENV=production

# Log verbosity: debug | info | warn | error
LOG_LEVEL=info

# Absolute path to frontend static assets directory
# STATIC_DIR=/app/frontend/dist

# Comma-separated list of allowed CORS origins (empty = no CORS headers)
# CORS_ORIGINS=http://localhost:5173
